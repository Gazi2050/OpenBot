{
  "name": "openbot-sdk",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js",
      "require": "./dist/chat.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@openbot/shared": "workspace:*"
  },
  "peerDependencies": {
    "@ai-sdk/svelte": "^4.0.0",
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/svelte": { "optional": true },
    "ai": { "optional": true }
  },
  "devDependencies": {
    "@ai-sdk/svelte": "^4.0.197",
    "ai": "^6.0.197",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
